---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

import { siteConfig } from "../site.config";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";
import { formatWordCount, getReadingStats } from "../utils/reading-stats";

interface Props {
	post: CollectionEntry<"post">;
	fullWidth?: boolean;
}

const { post } = Astro.props;
const { title, description, heroImage, pinned } = post.data;
const pubDate =
	post.data.pubDate ?? post.data.published ?? post.data.date ?? new Date(0);

// 计算文章字数
const readingStats = getReadingStats(post.body ?? "");
const wordCountText = i18n(I18nKey.wordCount, {
	count: formatWordCount(readingStats.wordCount),
});
const readingTimeText = i18n(I18nKey.readingTime, {
	minutes: readingStats.readingMinutes,
});

// 处理封面图逻辑
let coverImage = null;
if (
	siteConfig.randomImage &&
	siteConfig.randomImage.enable &&
	siteConfig.randomImage.ignoreHeroImage
) {
	// 如果开启了随机图且强制忽略 heroImage，使用带有 post.id 的 URL 确保每篇文章图不同
	coverImage = `${siteConfig.randomImage.url}?v=${post.id}`;
} else if (heroImage) {
	coverImage = typeof heroImage === "string" ? heroImage : heroImage.src;
} else if (siteConfig.randomImage && siteConfig.randomImage.enable) {
	// 使用带有 post.id 的 URL 确保每篇文章图不同
	coverImage = `${siteConfig.randomImage.url}?v=${post.id}`;
}
---

<a class="post" href={`/post/${post.id}/`}>
	<div class="mdui-card index-card mdui-hoverable">
		<div class="mdui-card-media index-img-media">
			<img
				class="index-img"
				src={coverImage}
				alt={title}
				loading="lazy"
				decoding="async"
			/>
			<div class="index-card-filter"></div>
			<div class="mdui-card-media-covered">
				<div class="mdui-card-primary index-primary">
					<div class="mdui-card-primary-title">
						{
							pinned && (
								<span class="mdui-text-color-theme" id="sticky">
									{i18n(I18nKey.sticky)}{" "}
								</span>
							)
						}
						{title}
					</div>
					<div class="mdui-card-primary-subtitle index-info">
						<FormattedDate date={pubDate} />
						| {wordCountText}
						| {readingTimeText}
					</div>
					<div class="mdui-card-primary-subtitle index-subtitle">
						{description}
					</div>
				</div>
			</div>
		</div>
	</div>
</a>
